{
  "id": "d6",
  "title": "How the log is organized",
  "category": "Information architecture",
  "version": "1.0",
  "phase": "Design",
  "type": "technical",
  "question": "What should the decision log be grouped by so it reads like a system, not a flat list?",
  "status": "decided",
  "rationale": "Group decisions by project stage (planning to upkeep) as the main structure, with topic as a secondary tag. This turns the log into a framework showing how the project moved through stages — topic alone or a plain list showed no stage.",
  "dependsOn": [
    "d2"
  ],
  "options": [
    {
      "id": "o6a",
      "label": "Group by project stage (topic as a tag)",
      "chosen": true,
      "tradeoffs": [
        {
          "criterion": "fits framework goal",
          "sentiment": "+",
          "note": "shows the decisions made at each stage"
        },
        {
          "criterion": "stage visibility",
          "sentiment": "+",
          "note": "see which stage each choice was made in"
        },
        {
          "criterion": "effort",
          "sentiment": "~",
          "note": "add a stage label and regroup the list"
        }
      ]
    },
    {
      "id": "o6b",
      "label": "Group by topic only",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "fits framework goal",
          "sentiment": "-",
          "note": "topic doesn't show the project stage"
        },
        {
          "criterion": "stage visibility",
          "sentiment": "-",
          "note": "no sense of which stage"
        },
        {
          "criterion": "effort",
          "sentiment": "+",
          "note": "already built"
        }
      ]
    },
    {
      "id": "o6c",
      "label": "Flat list by date",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "fits framework goal",
          "sentiment": "-",
          "note": "no structure or system"
        },
        {
          "criterion": "stage visibility",
          "sentiment": "-",
          "note": "shows order only, no grouping"
        },
        {
          "criterion": "effort",
          "sentiment": "+",
          "note": "very easy"
        }
      ]
    }
  ]
}
