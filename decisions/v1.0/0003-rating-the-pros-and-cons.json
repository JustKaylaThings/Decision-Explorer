{
  "id": "d3",
  "title": "Rating the pros and cons",
  "category": "Visualization",
  "version": "1.0",
  "phase": "Design",
  "type": "technical",
  "question": "How should each pro and con be recorded — as a simple good/bad/mixed mark, or as numbers that let the tool pick a winner?",
  "status": "decided",
  "dependsOn": [
    "d2"
  ],
  "rationale": "A hybrid keeps logging fast and honest by default using simple marks (plus, minus, mixed), but lets you add number scores for high-stakes decisions where a calculated recommendation is worth the extra effort. Best of both, without forcing fake precision on every entry.",
  "options": [
    {
      "id": "o3a",
      "label": "Simple marks only (good / bad / mixed)",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "build effort",
          "sentiment": "+",
          "note": "already done"
        },
        {
          "criterion": "can pick a winner",
          "sentiment": "-",
          "note": "no way to rank the options"
        },
        {
          "criterion": "honesty",
          "sentiment": "+",
          "note": "no fake precision"
        }
      ]
    },
    {
      "id": "o3b",
      "label": "Number scores",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "build effort",
          "sentiment": "-",
          "note": "needs a scoring screen plus the math"
        },
        {
          "criterion": "can pick a winner",
          "sentiment": "+",
          "note": "calculates a top choice"
        },
        {
          "criterion": "honesty",
          "sentiment": "-",
          "note": "risks fake precision"
        }
      ]
    },
    {
      "id": "o3c",
      "label": "Hybrid (marks by default, numbers optional)",
      "chosen": true,
      "tradeoffs": [
        {
          "criterion": "build effort",
          "sentiment": "~",
          "note": "marks now, number scoring added later"
        },
        {
          "criterion": "can pick a winner",
          "sentiment": "+",
          "note": "available when you want it"
        },
        {
          "criterion": "honesty",
          "sentiment": "~",
          "note": "precision only when you opt in"
        }
      ]
    }
  ]
}
