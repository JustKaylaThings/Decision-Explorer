{
  "id": "d1",
  "title": "How the tool is built",
  "category": "Architecture",
  "version": "1.0",
  "phase": "Design",
  "type": "technical",
  "question": "Should the decision tool be a Claude Code add-on (skill), a connected service (MCP), or its own website?",
  "status": "decided",
  "rationale": "A skill — a small add-on that runs inside Claude Code — is the simplest to build and improve, and needs no separate hosting. Chosen for the first version.",
  "options": [
    {
      "id": "o1a",
      "label": "Claude Code add-on (skill)",
      "chosen": true,
      "tradeoffs": [
        {
          "criterion": "build effort",
          "sentiment": "+",
          "note": "just an instructions file plus a script"
        },
        {
          "criterion": "saved between sessions",
          "sentiment": "~",
          "note": "kept as files on your computer, per project"
        },
        {
          "criterion": "easy to share",
          "sentiment": "-",
          "note": "only opens inside Claude Code"
        }
      ]
    },
    {
      "id": "o1b",
      "label": "Connected service (MCP add-on)",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "build effort",
          "sentiment": "-",
          "note": "needs a server running"
        },
        {
          "criterion": "saved between sessions",
          "sentiment": "+",
          "note": "stored in one shared database"
        }
      ]
    },
    {
      "id": "o1c",
      "label": "Its own website",
      "chosen": false,
      "tradeoffs": [
        {
          "criterion": "build effort",
          "sentiment": "-",
          "note": "most work, and needs hosting"
        },
        {
          "criterion": "easy to share",
          "sentiment": "+",
          "note": "anyone can open the link"
        }
      ]
    }
  ]
}
